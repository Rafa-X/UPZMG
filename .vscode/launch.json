{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UPZMG.Web",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/UPZMG.Web/bin/Debug/net9.0/UPZMG.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/UPZMG.Web",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "externalTerminal",
      "stopAtEntry": false,
      "sourceFileMap": {
        "${workspaceFolder}/src": "${workspaceFolder}/src"
      }
    },
    {
      "name": "UPZMG.Api",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/UPZMG.API/bin/Debug/net9.0/UPZMG.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/UPZMG.API",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "externalTerminal",
      "stopAtEntry": false,
      "sourceFileMap": {
        "${workspaceFolder}/src": "${workspaceFolder}/src"
      }
    }
  ],
  "compounds": [
    {
      "name": "UPZMG",
      "configurations": ["UPZMG.Web", "UPZMG.Api"]
    }
  ]
}

